// Polymorphic function composition with local dependent lambda
fn double(x: u64) -> u64 { x + x }

fn to_u8(x: u64) -> u8 { match x { 0 => 0, 1 => 1, 2 => 2, _ => 3 } }

fn test() -> u8 {
    let compose = |A: Type, B: Type, C: Type| |f: (fn(_: B) -> C), g: (fn(_: A) -> B)| |x: A| f(g(x));
    compose(u64, u64, u8)(to_u8, double)(5)
}

code fn result() -> u8 { $(test()) }
