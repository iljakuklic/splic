// Polymorphic function composition
fn compose(A: Type, B: Type, C: Type, f: fn(B) -> C, g: fn(A) -> B) -> fn(A) -> C {
    |x: A| f(g(x))
}

fn double(x: u64) -> u64 { x + x }
fn to_u8(x: u64) -> u8 { x }

fn test() -> u8 {
    compose(u64, u64, u8, to_u8, double)(5)
}

code fn result() -> u8 { $(test()) }
