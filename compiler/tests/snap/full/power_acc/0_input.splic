
fn power_acc(x: [[u64]], k: u64, r: [[u64]]) -> [[u64]] {
    match k {
        0 => r,
        k => {
            let odd: u64 = k & 1;
            #{
                let x1: u64 = $(x);
                $(match odd == 1 {
                    0 => power_acc(#(x1 * x1), k / 2, r),
                    1 => #{
                        $(power_acc(#(x1 * x1), k / 2, #($(r) * x1)))
                    },
                })
            }
        }
    }
}

fn power_acc_1(x: [[u64]], k: u64) -> [[u64]] {
    match k {
        0 => #(1),
        k => {
            let odd: u64 = k & 1;
            #{
                let x1: u64 = $(x);
                $(match odd == 1 {
                    0 => power_acc_1(#(x1 * x1), k / 2),
                    1 => power_acc(#(x1 * x1), k / 2, #(x1)),
                })
            }
        }
    }
}

fn power(x: [[u64]], k: u64) -> [[u64]] {
    power_acc_1(x, k)
}

code fn pow1(x: u64) -> u64 {
    $(power(#(x), 1))
}

code fn pow5(x: u64) -> u64 {
    $(power(#(x), 5))
}

code fn pow11_inc(x: u64) -> u64 {
    $(power(#({ let y: u64 = x + 1; y }), 11))
}

code fn pow15(x: u64) -> u64 {
    $(power(#(x), 15))
}

code fn pow16(x: u64) -> u64 {
    $(power(#(x), 16))
}

code fn pow17(x: u64) -> u64 {
    $(power(#(x), 17))
}
