// Function composition (monomorphic)
def compose(f: fn(_: u64) -> u64, g: fn(_: u64) -> u64) -> fn(_: u64) -> u64 = {
    lam(x: u64) = f(g(x))
};

def double(x: u64) -> u64 = { x + x };
def inc(x: u64) -> u64 = { x + 1 };

def test() -> u64 = {
    compose(double, inc)(5)
};

code def result() -> u64 = { $(test()) };
